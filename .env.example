# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# WHATSAPP_ACCESS_TOKEN: Meta System User Token for WhatsApp Cloud API.
WHATSAPP_ACCESS_TOKEN=YOUR_WHATSAPP_ACCESS_TOKEN_PLACEHOLDER

# WHATSAPP_PHONE_NUMBER_ID: Sender phone number ID from Meta Developers Panel.
WHATSAPP_PHONE_NUMBER_ID=YOUR_WHATSAPP_PHONE_NUMBER_ID_PLACEHOLDER

# WHATSAPP_TEMPLATE_NAME: Pre-approved template name (e.g., payment_reminder).
WHATSAPP_TEMPLATE_NAME=payment_reminder

# WHATSAPP_TEMPLATE_LANG: Pre-approved template language (e.g., en_US or hi).
WHATSAPP_TEMPLATE_LANG=en_US
